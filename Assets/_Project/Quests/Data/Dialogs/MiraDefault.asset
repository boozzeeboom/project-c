  treeId: mira_default
  displayName: "\u041C\u0438\u0440\u0430 \u2014 \u043E\u0431\u044B\u0447\u043D\u044B\u0439
    \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440"
  rootNodeId: greeting
  nodes:
  - nodeId: greeting
    speaker:
      speakerKind: 0
      refId: mira_01
    text: "\u041F\u0440\u0438\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E, \u0438\u0441\u043A\u0430\u0442\u0435\u043B\u044C.
      \u0427\u0435\u043C \u043C\u043E\u0433\u0443 \u043F\u043E\u043C\u043E\u0447\u044C?"
    portraitEmotion: neutral
    edges:
    - label: "\u0423 \u0442\u0435\u0431\u044F \u0435\u0441\u0442\u044C \u0440\u0430\u0431\u043E\u0442\u0430
        \u0434\u043B\u044F \u043C\u0435\u043D\u044F?"
      targetNodeId: offer_quest
      condition:
        type: 10
        stringParam: 1
        stageIdParam:
        intParam: 1
