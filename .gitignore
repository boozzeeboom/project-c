# Unity .gitignore Template
# Source: https://github.com/github/gitignore/blob/main/Unity.gitignore

# This .gitignore file should be placed at the root of your Unity project directory

.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# MemoryCaptures
/[Mm]emoryCaptures/

# Recordings
/[Rr]ecordings/

# Visual Studio
.vs/
*.csproj
*.sln
*.suo
*.user

# Mono
mono_crash.*

# Unity generated
*.pidb
*.pdb.meta
*.mdb.meta

# Addressables
/ServerData
/[Aa]ssets/StreamingAssets/aa*

# Visual Scripting
/[Aa]ssets/Unity.VisualScripting.Generated/

# Unity Package Manager
/[Aa]ssets/Resources/
/[Aa]ssets/MobileDependencyResolver/

# Dev memory (local session state)
.dev-memory/

# Archive folder (development artifacts, old sessions)
docs/archive/

# OpenCode Game Studio configuration (per-user)
.opencode/

# Agent configuration (personal - not for sharing)
.qwen/
.agents/           # Personal agent configs and skills
.cline/            # Cline agent files
.clinerules/       # Cline rules and hooks
.vscode/            # VSCode settings

# Graphify output (generated, per-session)
graphify-out/
.graphify_*
graphify_*.py

# Temporary files
*.tmp
*.temp
~*
