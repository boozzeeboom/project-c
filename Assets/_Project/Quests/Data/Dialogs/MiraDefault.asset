  - nodeId: accept_thanks
    speaker:
      speakerKind: 0
      refId: mira_01
    text: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430 \u043A\u043B\u044E\u0447.
      \u041F\u0440\u0438\u043D\u0435\u0441\u0438 \u041A\u0440\u0438\u0441\u0442\u0430\u043B\u043B
      \u0412\u0440\u0435\u043C\u0451\u043D \u2014 \u0438 \u043C\u044B \u0432 \u0440\u0430\u0441\u0447\u0451\u0442\u0435.
      \u0418\u0449\u0438 \u0432 \u0440\u0443\u0438\u043D\u0430\u0445 \u043D\u0430
      \u0432\u043E\u0441\u0442\u043E\u043A\u0435."
    portraitEmotion: neutral
    edges:
    - label: "\u0425\u043E\u0440\u043E\u0448\u043E."
      targetNodeId: 
      condition:
        type: 10
        stringParam: 
        stageIdParam: 
        intParam: 0
        factionParam: 0
        questStateParam: 2
      conditions: []
      action:
