        intParam: 0
        factionParam: 0
      hideIfUnavailable: 1
    - label: "\u041F\u043E\u043A\u0430."
      targetNodeId: 
      condition:
        type: 10
        stringParam: 
        stageIdParam: 
        intParam: 0
        factionParam: 0
        questStateParam: 2
      conditions: []
      action:
