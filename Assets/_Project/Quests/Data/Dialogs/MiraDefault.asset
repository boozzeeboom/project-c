  - nodeId: no_b
    speaker:
      speakerKind: 0
      refId: mira_01
    text: "\u041D\u0435 \u0432\u0438\u0436\u0443 \u0443 \u0442\u0435\u0431\u044F
      \u041A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u0430. \u0418\u0434\u0438
      \u0438\u0449\u0438."
    portraitEmotion: serious
