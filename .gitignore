# Unity .gitignore Template
# Source: https://github.com/github/gitignore/blob/main/Unity.gitignore

# This .gitignore file should be placed at the root of your Unity project directory

.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

#assets
*[Tt]extures
*[Ss]creenshots

# MemoryCaptures
/[Mm]emoryCaptures/

# Recordings
/[Rr]ecordings/

# Visual Studio
.vs/
*.csproj
*.sln
*.suo
*.user
*.graphifyignore


# Mono
mono_crash.*

# Unity generated
*.pidb
*.pdb.meta
*.mdb.meta

# Addressables
/ServerData
/[Aa]ssets/StreamingAssets/aa*

# Visual Scripting
/[Aa]ssets/Unity.VisualScripting.Generated/

# Unity Package Manager
/[Aa]ssets/Resources/
/[Aa]ssets/MobileDependencyResolver/

#items_a lot of
/[Aa]ssets/_Project/Resources/_docs/
/[Aa]ssets/_Project/Trade/Data/Items/
/[Aa]ssets/_Project/Resources/Items/
#quests_a lot of
/[Aa]ssets/_Project/Quests/Data/Quests
/[Aa]ssets/_Project/Quests/Data/Factions
/[Aa]ssets/_Project/Quests/Data/Npcs
/[Aa]ssets/_Project/Quests/Data/Import
/[Aa]ssets/Generated_Images*
/[Aa]Assets/Generated_Models*

# Dev memory (local session state)
.dev-memory/

# Archive folder (development artifacts, old sessions)
docs/archive/

# OpenCode Game Studio configuration (per-user)
.opencode/

# Agent configuration (personal - not for sharing)
.qwen/
# Personal agent configs and skills
.agents/
# Cline agent files
.cline/
# Cline rules and hooks
.clinerules/
# VSCode settings
.vscode/
#hermes
*.hermes/
#Aura
*.Aura
[Pp]ackages/Aura


# Graphify output (generated, per-session)
# Root output with exceptions for git tracking
graphify-out/**
!/graphify-out/graph.json
!/graphify-out/GRAPH_REPORT.md

# All graphify subdirs (nested in Assets, docs, etc.)
**/graphify-out/

# Graphify temp files (per-session extracted data — root + all subdirs)
**/.graphify_*
**/graphify_*.py

# Local graph data for WordPress iframe embedding
docs/graph.json
docs/vis-network.min.js
docs/graph.html

# Agent configs (generated, per-user)
AGENTS.md

# Temporary files
*.tmp
*.temp
~*

# Node.js
node_modules/
package.json
package-lock.json

# Test files
test-pirate.js
# MoonMaterial — not for version control (regenerated by Unity)
Assets/_Project/ScriptableObjects/DayNight/MoonMaterial.mat*
Assets/_Project/Materials/Moon/MoonMaterial.mat*
#humanbasic_free
/[Aa]ssets/Kevin Iglesias*
Packages/manifest.json
Packages/packages-lock.json
*.aura_temp
.gitignore
Assets/_Project/Scenes/World/WorldScene_0_0.zip
