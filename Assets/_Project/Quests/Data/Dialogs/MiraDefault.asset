  - nodeId: not_yet
    speaker:
      speakerKind: 0
      refId: mira_01
    text: "\u041E\u043A, \u043A\u0430\u043A \u043D\u0430\u0439\u0434\u0451\u0448\u044C
      \u2014 \u043F\u0440\u0438\u043D\u043E\u0441\u0438."
    portraitEmotion: neutral
    edges:
    - label: "\u0414\u043E \u0441\u0432\u0438\u0434\u0430\u043D\u0438\u044F."
