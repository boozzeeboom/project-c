  - nodeId: check_b
    speaker:
      speakerKind: 0
      refId: mira_01
    text: "\u041D\u0443 \u0447\u0442\u043E, \u043D\u0430\u0448\u0451\u043B \u041A\u0440\u0438\u0441\u0442\u0430\u043B\u043B
      \u0412\u0440\u0435\u043C\u0451\u043D?"
