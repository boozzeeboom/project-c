  - nodeId: complete_thanks
    speaker:
      speakerKind: 0
      refId: mira_01
    text: "\u041D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E! \u042D\u0442\u043E
      \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043E\u043D! \u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0442\u0435\u0431\u0435.
      \u0412\u043E\u0442 \u0442\u0432\u043E\u044F \u043D\u0430\u0433\u0440\u0430\u0434\u0430
      \u2014 1000 \u043A\u0440\u0435\u0434\u0438\u0442\u043E\u0432 \u0438 \u043C\u043E\u044F
      \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u043D\u043E\u0441\u0442\u044C."
    portraitEmotion: happy
