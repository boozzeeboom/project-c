        intParam: 0
        factionParam: 0
      hideIfUnavailable: 1
    onEnterActions: []
  - nodeId: offer_quest
    speaker:
      speakerKind: 0
      refId: mira_01
    text: "\u0423 \u043C\u0435\u043D\u044F \u0435\u0441\u0442\u044C \u0434\u0435\u043B\u043E.
      \u041C\u043D\u0435 \u043D\u0443\u0436\u0435\u043D \u041A\u0440\u0438\u0441\u0442\u0430\u043B\u043B
      \u0412\u0440\u0435\u043C\u0451\u043D \u2014 \u044D\u0442\u043E \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442
      \u0413\u0438\u043B\u044C\u0434\u0438\u0438 \u041C\u044B\u0441\u043B\u0438.
      \u0415\u0441\u043B\u0438 \u043F\u0440\u0438\u043D\u0435\u0441\u0451\u0448\u044C
      \u2014 \u0445\u043E\u0440\u043E\u0448\u043E \u0437\u0430\u043F\u043B\u0430\u0447\u0443.
      \u041F\u0440\u0430\u0432\u0434\u0430, \u0443 \u043C\u0435\u043D\u044F \u0441\u0435\u0439\u0447\u0430\u0441
      \u043D\u0435\u0442 \u0437\u0430\u0434\u0430\u0442\u043A\u0430, \u0437\u0430\u0431\u0435\u0440\u0443
      \u0442\u0432\u043E\u0439 \u0414\u0440\u0435\u0432\u043D\u0438\u0439 \u041A\u043B\u044E\u0447
      \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u043E\u043F\u043B\u0430\u0442\u044B
      \u0430\u0432\u0430\u043D\u0441\u043E\u043C."
    portraitEmotion: serious
    edges:
    - label: "\u042F \u043F\u043E\u043C\u043E\u0433\u0443."
      targetNodeId: accept_thanks
      condition:
        type: 10
        stringParam: 
        stageIdParam: 
        intParam: 0
        factionParam: 0
        questStateParam: 2
      conditions: []
      action:
        type: 21
        stringParam: 1
        stageIdParam: 
        intParam: 1
        factionParam: 0
      hideIfUnavailable: 0
    - label: "\u041D\u0435\u0442, \u043D\u0435 \u0445\u043E\u0447\u0443."
      targetNodeId: decline
      condition:
        type: 10
        stringParam: 
        stageIdParam: 
