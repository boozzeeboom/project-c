  - nodeId: quest_complete
    speaker:
      speakerKind: 0
      refId: mira_01
    text: "\u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044E \u0442\u0435\u0431\u044F
      \u043E\u0442 \u0438\u043C\u0435\u043D\u0438 \u0432\u0441\u0435\u0439 \u0413\u0438\u043B\u044C\u0434\u0438\u0438.
