  - nodeId: offer_quest
    speaker:
      speakerKind: 0
      refId: mira_01
    text: "\u0414\u0430, \u0443 \u043C\u0435\u043D\u044F \u0435\u0441\u0442\u044C
      \u0434\u0435\u043B\u043E. \u042F \u0438\u0449\u0443 \u041A\u0440\u0438\u0441\u0442\u0430\u043B\u043B
      \u0412\u0440\u0435\u043C\u0451\u043D \u2014 \u0443\u0442\u0435\u0440\u044F\u043D\u043D\u044B\u0439
      \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442 \u0413\u0438\u043B\u044C\u0434\u0438\u0438.
      \u0415\u0441\u043B\u0438 \u043D\u0430\u0439\u0434\u0451\u0448\u044C \u2014
      \u043E\u0437\u043E\u043B\u043E\u0447\u0443."
    portraitEmotion: serious
    edges:
    - label: "\u042F \u043F\u043E\u043C\u043E\u0433\u0443. (\u041F\u0440\u0438\u043D\u044F\u0442\u044C
        \u043A\u0432\u0435\u0441\u0442)"
