  - nodeId: guild_info
    speaker:
      speakerKind: 0
      refId: mira_01
    text: "\u0413\u0438\u043B\u044C\u0434\u0438\u044F \u041C\u044B\u0441\u043B\u0438
      \u2014 \u044D\u0442\u043E \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E
      \u0443\u0447\u0451\u043D\u044B\u0445, \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432
      \u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439.
      \u041C\u044B \u0438\u0449\u0435\u043C \u0437\u043D\u0430\u043D\u0438\u044F
      \u0432\u0435\u0437\u0434\u0435, \u0433\u0434\u0435 \u0435\u0441\u0442\u044C
      \u0442\u0435\u043D\u044C..."
    portraitEmotion: thoughtful
    edges:
    - label: "\u041F\u043E\u043D\u044F\u0442\u043D\u043E. \u0420\u0430\u0441\u0441\u043A\u0430\u0436\u0438
        \u0435\u0449\u0451 \u043E \u0447\u0451\u043C-\u043D\u0438\u0431\u0443\u0434\u044C."
